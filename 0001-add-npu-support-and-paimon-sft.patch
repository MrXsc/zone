+#!/usr/bin/env python3
+"""为 CosyVoice3 SFT 准备派蒙语音数据，生成 Kaldi 格式文件。"""
+
+import os
+import re
+import random
+
+RAW_DIR = "/home/xs/data/paimon_raw"
+OUT_DIR = "/home/xs/data/paimon_sft"
+SPK = "paimon"
+TRAIN_NUM = 4000
+VAL_NUM = 400
+SEED = 42
+
+def clean_text(text):
+    """清理文本：去标点、空白、特殊字符"""
+    text = re.sub(r'[^\u4e00-\u9fff\u3000-\u303fa-zA-Z0-9]', '', text)
+    text = text.strip()
+    return text
+
+def main():
+    random.seed(SEED)
+    os.makedirs(os.path.join(OUT_DIR, "train"), exist_ok=True)
+    os.makedirs(os.path.join(OUT_DIR, "val"), exist_ok=True)
+
+    # 收集所有 wav 和对应 lab
+    entries = []
+    for f in sorted(os.listdir(RAW_DIR)):
+        if f.endswith(".wav"):
+            wav_path = os.path.join(RAW_DIR, f)
+            lab_path = os.path.join(RAW_DIR, f.replace(".wav", ".lab"))
+            if os.path.exists(lab_path):
+                with open(lab_path, "r", encoding="utf-8") as lf:
+                    text = clean_text(lf.read())
+                if len(text) > 0:
+                    utt_id = f.replace(".wav", "")
+                    entries.append((utt_id, wav_path, text))
+
+    print(f"Total valid entries: {len(entries)}")
+    random.shuffle(entries)
+
+    splits = {"train": entries[:TRAIN_NUM], "val": entries[TRAIN_NUM:TRAIN_NUM + VAL_NUM]}
+
+    for split, data in splits.items():
+        dir_path = os.path.join(OUT_DIR, split)
+        with open(os.path.join(dir_path, "wav.scp"), "w") as f_wav, \
+             open(os.path.join(dir_path, "text"), "w") as f_txt, \
+             open(os.path.join(dir_path, "utt2spk"), "w") as f_u2s:
+            for utt_id, wav_path, text in data:
+                f_wav.write(f"{utt_id}\t{wav_path}\n")
+                f_txt.write(f"{utt_id}\t{text}\n")
+                f_u2s.write(f"{utt_id}\t{SPK}\n")
+        # spk2utt
+        spk2utt = {SPK: [d[0] for d in data]}
+        with open(os.path.join(dir_path, "spk2utt"), "w") as f:
+            for spk, utts in spk2utt.items():
+                f.write(f"{spk}\t{' '.join(utts)}\n")
+        print(f"{split}: {len(data)} entries")
+
+    print("Done!")
+
+if __name__ == "__main__":
+    main()
