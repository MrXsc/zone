+#!/bin/bash
+# CosyVoice3 派蒙 SFT 训练脚本 (NPU/Ascend910)
+set -e
+
+# --- 环境变量与基础配置 ---
+export ASCEND_RT_VISIBLE_DEVICES="8,9"          # 使用的 NPU 卡号，按需修改
+
+source /usr/local/Ascend/ascend-toolkit/set_env.sh 2>/dev/null
+
+cd /home/xs/code/CosyVoice
+export PYTHONPATH=$PYTHONPATH:$(pwd):$(pwd)/third_party/Matcha-TTS
+
+num_gpus=2                                    # 单卡，多卡按 ASCEND_RT_VISIBLE_DEVICES 配
+job_id=20260618
+dist_backend="hccl"                           # NPU 分布式后端
+
+num_workers=2
+prefetch=100
+train_engine=torch_ddp
+pretrained_model_dir=/home/xs/models/CosyVoice3-0.5B-2512
+data_root=/home/xs/data/paimon_sft
+
+# --- 生成 parquet 数据（若已存在则跳过）---
+for split in train val; do
+    parquet_dir=${data_root}/${split}/parquet
+    if [ ! -f ${parquet_dir}/data.list ]; then
+        echo "Generating parquet for ${split}..."
+        python tools/make_parquet_list.py \
+            --src_dir ${data_root}/${split} \
+            --des_dir ${parquet_dir} \
+            --num_utts_per_parquet 1000 \
+            --num_processes 1
+    fi
+done
+
+# --- 生成 spk2info.pt（若不存在）---
+spk2info=${data_root}/train/spk2info.pt
+if [ ! -f ${spk2info} ]; then
+    echo "Generating spk2info.pt..."
+    python - <<'EOF'
+import torch
+spk2embedding = torch.load('/home/xs/data/paimon_sft/train/spk2embedding.pt')
+spk2info = {spk: {'embedding': emb} for spk, emb in spk2embedding.items()}
+torch.save(spk2info, '/home/xs/data/paimon_sft/train/spk2info.pt')
+print('spk2info.pt saved:', list(spk2info.keys()))
+EOF
+fi
+
+# --- 准备 data.list ---
+# 跑通测试: train 和 cv 都用 val(400条) 数据
+echo "Preparing data list (smoke test: train & cv both use val data)..."
+cat ${data_root}/val/parquet/data.list > train.data.list
+cat ${data_root}/val/parquet/data.list > dev.data.list
+
+# --- 执行训练 (llm, flow, hift) ---
+echo "Starting training for llm, flow, hift..."
+for model in llm flow hift; do
+    echo "========== Training ${model} =========="
+    torchrun --nnodes=1 --nproc_per_node=${num_gpus} \
+        --rdzv_id=${job_id} --rdzv_backend="c10d" --rdzv_endpoint="localhost:1234" \
+        cosyvoice/bin/train.py \
+        --train_engine ${train_engine} \
+        --config examples/libritts/cosyvoice3/conf/cosyvoice3.yaml \
+        --train_data train.data.list \
+        --cv_data dev.data.list \
+        --model ${model} \
+        --qwen_pretrain_path ${pretrained_model_dir}/CosyVoice-BlankEN \
+        --checkpoint ${pretrained_model_dir}/${model}.pt \
+        --model_dir $(pwd)/exp/paimon_sft/${model}/${train_engine} \
+        --tensorboard_dir $(pwd)/tensorboard/paimon_sft/${model}/${train_engine} \
+        --ddp.dist_backend ${dist_backend} \
+        --num_workers ${num_workers} \
+        --pin_memory \
+        --onnx_path ${pretrained_model_dir}
+done
+
+echo "All training done."
+
+
+#  bash run_paimon_sft.sh > /home/xs/code/CosyVoice/train_paimon.log 2>&1 &
