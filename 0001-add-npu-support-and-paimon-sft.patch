diff --git a/cosyvoice/hifigan/generator.py b/cosyvoice/hifigan/generator.py
index bbc2a21..a3b9297 100644
--- a/cosyvoice/hifigan/generator.py
+++ b/cosyvoice/hifigan/generator.py
@@ -489,20 +489,29 @@ class HiFTGenerator(nn.Module):
             l.remove_weight_norm()
 
     def _stft(self, x):
+        # dtype问题 bf16 input, 用fp32计算
+        x_float = x.float()
+
         spec = torch.stft(
-            x,
+            x_float,
             self.istft_params["n_fft"], self.istft_params["hop_len"], self.istft_params["n_fft"], window=self.stft_window.to(x.device),
             return_complex=True)
-        spec = torch.view_as_real(spec)  # [B, F, TT, 2]
-        return spec[..., 0], spec[..., 1]
+        # spec = torch.view_as_real(spec)  # [B, F, TT, 2]
+        spec_real = torch.view_as_real(spec)[..., 0]
+        spec_imag = torch.view_as_real(spec)[..., 1]
+
+        return spec_real.to(x.dtype), spec_imag.to(x.dtype)
+        # return spec[..., 0], spec[..., 1]
 
     def _istft(self, magnitude, phase):
+        device = magnitude.device 
         magnitude = torch.clip(magnitude, max=1e2)
         real = magnitude * torch.cos(phase)
         img = magnitude * torch.sin(phase)
-        inverse_transform = torch.istft(torch.complex(real, img), self.istft_params["n_fft"], self.istft_params["hop_len"],
-                                        self.istft_params["n_fft"], window=self.stft_window.to(magnitude.device))
-        return inverse_transform
+        # cpu
+        inverse_transform = torch.istft(torch.complex(real.cpu(), img.cpu()).contiguous(), self.istft_params["n_fft"], self.istft_params["hop_len"],
+                                        self.istft_params["n_fft"], window=self.stft_window.cpu())
+        return inverse_transform.to(device)
 
     def decode(self, x: torch.Tensor, s: torch.Tensor = torch.zeros(1, 1, 0)) -> torch.Tensor:
         s_stft_real, s_stft_imag = self._stft(s.squeeze(1))
